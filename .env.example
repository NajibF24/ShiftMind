# Database
POSTGRES_USER=shiftmind_user
POSTGRES_PASSWORD=shiftmind_password
POSTGRES_DB=shiftmind_db

# JWT
JWT_SECRET_KEY=replace_this_with_a_secure_random_string_in_production

# 9Router Configuration
NINEROUTER_BASE_URL=http://host.docker.internal:20128/v1
NINEROUTER_API_KEY=sk-local-dev
NINEROUTER_MODEL=openai/gpt-4o-mini

# Microsoft Graph / OneDrive
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret
MS_ONEDRIVE_USER_ID=admin@yourdomain.com
MS_ONEDRIVE_ROOT_FOLDER=GYS Procedures and Policy

# LDAP / Active Directory
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=
LDAP_SEARCH_FILTER=
LDAP_USERNAME_ATTRIBUTE=
LDAP_MAIL_ATTRIBUTE=
LDAP_DISPLAYNAME_ATTRIBUTE=
LDAP_FIRSTNAME_ATTRIBUTE=
LDAP_LASTNAME_ATTRIBUTE=

# Admin whitelist: comma-separated sAMAccountNames that get admin role
LDAP_ADMIN_USERS=

# Web Scraper & Auto Sync
AUTO_SYNC_HOUR=
POWERBI_USERNAME=
POWERBI_PASSWORD=
POWERBI_URL=
